{
  "name": "content-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Content pipeline tool for Macroscope",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --build"
  },
  "engines": {
    "node": ">=20"
  }
}
