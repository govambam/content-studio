# Content Studio — Environment Variables
# Copy to .env and fill in values.
# See docs/SETUP-GUIDE.md for how to obtain each one.

# Anthropic API Key (for Claude workers)
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Railway / Runtime
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
